<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.ai.mapper.AlarmMapper">
    <resultMap type="Alarm" id="AlarmResult">
        <result property="alarmId"    column="alarm_id"    />
        <result property="alarmTitle"    column="alarm_title"    />
        <result property="alarmLevel"    column="alarm_level"    />
        <result property="alarmType"    column="alarm_type"    />
        <result property="alarmContent"    column="alarm_content"    />
        <result property="status"    column="status"    />
        <result property="triggerTime"    column="trigger_time"    />
        <result property="handleTime"    column="handle_time"    />
        <result property="handler"    column="handler"    />
        <result property="handleResult"    column="handle_result"    />
        <result property="alarmSource"    column="alarm_source"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectAlarmVo">
        select alarm_id, alarm_title, alarm_level, alarm_type, alarm_content, status, trigger_time, handle_time, handler, handle_result, alarm_source, del_flag, create_by, create_time, update_by, update_time, remark
        from ai_alarm
    </sql>

    <select id="selectAlarmList" parameterType="Alarm" resultMap="AlarmResult">
        <include refid="selectAlarmVo"/>
        <where>
            <if test="alarmTitle != null  and alarmTitle != ''"> and alarm_title like concat('%', #{alarmTitle}, '%')</if>
            <if test="alarmLevel != null  and alarmLevel != ''"> and alarm_level = #{alarmLevel}</if>
            <if test="alarmType != null  and alarmType != ''"> and alarm_type = #{alarmType}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="alarmSource != null  and alarmSource != ''"> and alarm_source = #{alarmSource}</if>
            <if test="params.beginTriggerTime != null and params.beginTriggerTime != ''"><!-- 开始时间检索 -->
                and date_format(trigger_time,'%y%m%d') &gt;= date_format(#{params.beginTriggerTime},'%y%m%d')
            </if>
            <if test="params.endTriggerTime != null and params.endTriggerTime != ''"><!-- 结束时间检索 -->
                and date_format(trigger_time,'%y%m%d') &lt;= date_format(#{params.endTriggerTime},'%y%m%d')
            </if>
            <if test="delFlag != null  and delFlag != ''"> and del_flag = #{delFlag}</if>
        </where>
        order by trigger_time desc
    </select>

    <select id="selectAlarmByAlarmId" parameterType="Long" resultMap="AlarmResult">
        <include refid="selectAlarmVo"/>
        where alarm_id = #{alarmId}
    </select>

    <insert id="insertAlarm" parameterType="Alarm" useGeneratedKeys="true" keyProperty="alarmId" keyColumn="alarm_id">
        insert into ai_alarm
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="alarmTitle != null">alarm_title,</if>
            <if test="alarmLevel != null">alarm_level,</if>
            <if test="alarmType != null">alarm_type,</if>
            <if test="alarmContent != null">alarm_content,</if>
            <if test="status != null">status,</if>
            <if test="triggerTime != null">trigger_time,</if>
            <if test="handleTime != null">handle_time,</if>
            <if test="handler != null">handler,</if>
            <if test="handleResult != null">handle_result,</if>
            <if test="alarmSource != null">alarm_source,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="alarmTitle != null">#{alarmTitle},</if>
            <if test="alarmLevel != null">#{alarmLevel},</if>
            <if test="alarmType != null">#{alarmType},</if>
            <if test="alarmContent != null">#{alarmContent},</if>
            <if test="status != null">#{status},</if>
            <if test="triggerTime != null">#{triggerTime},</if>
            <if test="handleTime != null">#{handleTime},</if>
            <if test="handler != null">#{handler},</if>
            <if test="handleResult != null">#{handleResult},</if>
            <if test="alarmSource != null">#{alarmSource},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateAlarm" parameterType="Alarm">
        update ai_alarm
        <trim prefix="SET" suffixOverrides=",">
            <if test="alarmTitle != null">alarm_title = #{alarmTitle},</if>
            <if test="alarmLevel != null">alarm_level = #{alarmLevel},</if>
            <if test="alarmType != null">alarm_type = #{alarmType},</if>
            <if test="alarmContent != null">alarm_content = #{alarmContent},</if>
            <if test="status != null">status = #{status},</if>
            <if test="triggerTime != null">trigger_time = #{triggerTime},</if>
            <if test="handleTime != null">handle_time = #{handleTime},</if>
            <if test="handler != null">handler = #{handler},</if>
            <if test="handleResult != null">handle_result = #{handleResult},</if>
            <if test="alarmSource != null">alarm_source = #{alarmSource},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where alarm_id = #{alarmId}
    </update>

    <delete id="deleteAlarmByAlarmId" parameterType="Long">
        delete from ai_alarm where alarm_id = #{alarmId}
    </delete>

    <delete id="deleteAlarmByAlarmIds" parameterType="Long">
        delete from ai_alarm where alarm_id in
        <foreach item="alarmId" collection="array" open="(" separator="," close=")">
            #{alarmId}
        </foreach>
    </delete>
</mapper>